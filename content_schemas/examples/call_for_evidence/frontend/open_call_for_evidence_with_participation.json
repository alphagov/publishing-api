  "base_path": "/government/calls-for-evidence/post-office-network",
  "description": "We are seeking views on the accessibility of post offices, the services available, and the role of communities in the future of the network.",
  "public_updated_at": "2016-11-08T11:00:00+00:00",
  "title": "Post Office network call for evidence",
  "updated_at": "2016-11-08T12:52:46.734Z",
  "schema_name": "call_for_evidence",
  "document_type": "open_call_for_evidence",
  "locale": "en",
  "details": {
    "body": "<div class=\"govspeak\"><p>Government provides funding to maintain a national network of post office branches that is accessible to everyone. We want you to tell us what you expect from the post office network.</p>\n\n<p>Your responses will be used to help determine the funding provided to the post office after the existing agreement with Post Office Limited ends in 2018.</p>\n\n<p>We are not proposing any changes to the network through this call for evidence.</p>\n</div>",
    "first_public_at": "2016-11-08T11:00:00+00:00",
