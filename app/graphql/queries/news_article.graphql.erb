<%= render "fragments/default_top_level_fields" %>
<%= render "fragments/available_translations" %>
<%= render "fragments/document_collections" %>
<%= render "fragments/government" %>
<%= render "fragments/ordered_related_items" %>
<%= render "fragments/organisations" %>
<%= render "fragments/original_primary_publishing_organisation" %>
<%= render "fragments/primary_publishing_organisation" %>
<%= render "fragments/roles" %>
<%= render "fragments/suggested_ordered_related_items" %>
<%= render "fragments/taxons" %>
<%= render "fragments/world_locations" %>

query news_article($base_path: String!) {
  edition(base_path: $base_path) {
    ... on Edition {
      ...DefaultTopLevelFields
      details {
        attachments {
          accessible
          alternative_format_contact_email
          attachment_type
          content_type
          file_size
          filename
          id
          locale
          number_of_pages
          preview_url
          title
          url
        }
        body
        change_history {
          note
          public_timestamp
        }
        emphasised_organisations
        first_public_at
        government {
          current
          slug
          title
        }
        image {
          alt_text
          caption
          credit
          high_resolution_url
          url
        }
        political
        tags {
          topics
        }
      }
      links {
        ...AvailableTranslations
        ...Government
        ...Organisations
        ...OriginalPrimaryPublishingOrganisation
        ...PrimaryPublishingOrganisation
        ...Taxons
        people {
          api_path
          api_url
          base_path
          content_id
          document_type
          locale
          public_updated_at
          schema_name
          title
          web_url
        }
        ...Roles
        ...SuggestedOrderedRelatedItems
        ...DocumentCollections
        ...WorldLocations
        topical_events {
          api_path
          api_url
          base_path
          content_id
          document_type
          locale
          public_updated_at
          schema_name
          title
          web_url
        }
        worldwide_organisations {
          analytics_identifier
          api_path
          api_url
          base_path
          content_id
          description
          details {
            default_news_image {
              high_resolution_url
              url
            }
            logo {
              crest
              formatted_title
            }
            world_location_names {
              content_id
              name
            }
          }
          document_type
          locale
          public_updated_at
          schema_name
          title
          web_url
        }
        ...OrderedRelatedItems
        ordered_related_items_overrides {
          api_path
          api_url
          base_path
          content_id
          document_type
          links {
            ...Taxons
          }
          locale
          public_updated_at
          schema_name
          title
          web_url
        }
      }
      withdrawn_notice {
        explanation
        withdrawn_at
      }
    }
  }
}
